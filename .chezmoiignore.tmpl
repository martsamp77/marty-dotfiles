# ══════════════════════════════════════════════════════════════════════════════
#  .chezmoiignore
#
#  Files listed here exist in the chezmoi SOURCE directory but are NOT
#  deployed to $HOME.  Use this for repository metadata, documentation,
#  and any file that belongs in the repo but not in your home directory.
# ══════════════════════════════════════════════════════════════════════════════

# Repository documentation and scripts — live in the repo, not in ~/
README.md
CHANGELOG.md
install.sh
install-starship.ps1
install-powershell.ps1

# Cursor settings source files — deployed by run_after_apply-cursor.sh,
# not directly to $HOME.  The run_after script copies these to the
# OS-specific Cursor settings directory.
cursor

# Helper scripts — invoked manually, not deployed to ~/
scripts

{{- if ne .chezmoi.os "windows" }}
# PowerShell profiles — Windows only (pwsh + Windows PowerShell 5.1)
Documents/PowerShell/Microsoft.PowerShell_profile.ps1
Documents/WindowsPowerShell/Microsoft.PowerShell_profile.ps1
{{- end }}
