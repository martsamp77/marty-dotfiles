#!/bin/bash
# ══════════════════════════════════════════════════════════════════════════════
#  run_after_apply-cursor.sh.tmpl
#
#  Deploys Cursor and VS Code IDE settings to the correct OS-specific path
#  after chezmoi apply.  Handles macOS, native Linux, and WSL (where Cursor
#  and VS Code run on the Windows side but chezmoi runs inside WSL).
#
#  Managed files:
#    cursor/settings.json    → editor preferences, theme, Peacock colors
#    keybindings.json        → generated inline (OS-aware workspace path)
#    cursor/extensions.txt   → manifest; install via scripts/cursor-sync-extensions.sh
#
#  Files NOT managed (binary / machine-local):
#    state.vscdb             → SQLite blob (User Rules, chat history, UI state)
#    ~/.cursor/extensions/   → installed extension packages
#
#  Usage:
#    Runs automatically on `chezmoi apply` / `chezmoi update`.
#    Manual:  chezmoi apply --include=always
# ══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

CHEZMOI_SOURCE="{{ .chezmoi.sourceDir }}"

# ── Detect OS and set IDE settings paths ────────────────────────────────────
{{ if eq .chezmoi.os "darwin" }}
CURSOR_DIR="$HOME/Library/Application Support/Cursor/User"
CURSOR_CMD="cursor"
CODE_DIR="$HOME/Library/Application Support/Code/User"
CODE_CMD="code"
WORKSPACE_PATH="$HOME/Workspace"
{{ else }}
# Linux — check for WSL (Cursor runs on the Windows side)
if [[ -f /proc/version ]] && grep -qi microsoft /proc/version 2>/dev/null; then
    # WSL: resolve the Windows AppData path
    WIN_APPDATA=$(wslpath "$(cmd.exe /c "echo %APPDATA%" 2>/dev/null | tr -d '\r')")
    CURSOR_DIR="${WIN_APPDATA}/Cursor/User"
    CURSOR_CMD="cursor.exe"
    # Fallback: Cursor in Program Files when not in PATH
    if ! command -v "$CURSOR_CMD" &>/dev/null; then
        CURSOR_FALLBACK="/mnt/c/Program Files/cursor/resources/app/bin/cursor"
        [[ -x "$CURSOR_FALLBACK" ]] && CURSOR_CMD="$CURSOR_FALLBACK"
    fi
    CODE_DIR="${WIN_APPDATA}/Code/User"
    CODE_CMD="code.exe"
    if ! command -v "$CODE_CMD" &>/dev/null; then
        CODE_FALLBACK="/mnt/c/Program Files/Microsoft VS Code/bin/code"
        [[ -x "$CODE_FALLBACK" ]] && CODE_CMD="$CODE_FALLBACK"
    fi
    WORKSPACE_PATH="C:\\\\Workspace"
else
    # Native Linux
    CURSOR_DIR="$HOME/.config/Cursor/User"
    CURSOR_CMD="cursor"
    CODE_DIR="$HOME/.config/Code/User"
    CODE_CMD="code"
    WORKSPACE_PATH="$HOME/Workspace"
fi
{{ end }}

# ── Cursor: deploy if installed ────────────────────────────────────────────
if [[ -d "$CURSOR_DIR" ]]; then
# ── Deploy settings.json ────────────────────────────────────────────────────
SETTINGS_SRC="${CHEZMOI_SOURCE}/cursor/settings.json"
if [[ -f "$SETTINGS_SRC" ]]; then
    cp "$SETTINGS_SRC" "$CURSOR_DIR/settings.json"
    echo "  cursor: settings.json deployed"
else
    echo "  cursor: settings.json not found in source — skipping"
fi

# ── Deploy keybindings.json (generated with OS-aware paths) ─────────────────
cat > "$CURSOR_DIR/keybindings.json" << KEYBINDINGS_EOF
// Place your key bindings in this file to override the defaults
[
    {
        "key": "ctrl+i",
        "command": "composerMode.agent"
    },
    {
        "key": "ctrl+alt+s",
        "command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
        "when": "cursor.agentIdeUnification.enabled == true && !isAuxiliaryWindowFocusedContext"
    },
    {
        "key": "ctrl+o ctrl+m",
        "command": "workbench.action.files.openFolder",
        "args": { "defaultUri": "$WORKSPACE_PATH" }
    }
]
KEYBINDINGS_EOF
echo "  cursor: keybindings.json deployed"

# ── Deploy snippets (if any exist in source) ────────────────────────────────
SNIPPETS_SRC="${CHEZMOI_SOURCE}/cursor/snippets"
if [[ -d "$SNIPPETS_SRC" ]] && ls "$SNIPPETS_SRC"/*.code-snippets &>/dev/null; then
    mkdir -p "$CURSOR_DIR/snippets"
    cp "$SNIPPETS_SRC"/*.code-snippets "$CURSOR_DIR/snippets/"
    echo "  cursor: snippets deployed"
fi

# Extensions: use ./scripts/cursor-sync-extensions.sh when needed (not on every apply)

# ── Deploy global MCP config (if present) ───────────────────────────────────
MCP_SRC="${CHEZMOI_SOURCE}/cursor/mcp.json"
if [[ -f "$MCP_SRC" ]]; then
    mkdir -p "$HOME/.cursor"
    cp "$MCP_SRC" "$HOME/.cursor/mcp.json"
    echo "  cursor: global mcp.json deployed"
fi
else
    echo "  cursor: settings directory not found — skipping ($CURSOR_DIR)"
fi

# ── VS Code: deploy if installed ───────────────────────────────────────────
if [[ -d "$CODE_DIR" ]]; then
SETTINGS_SRC="${CHEZMOI_SOURCE}/cursor/settings.json"
if [[ -f "$SETTINGS_SRC" ]]; then
    cp "$SETTINGS_SRC" "$CODE_DIR/settings.json"
    echo "  vscode: settings.json deployed"
else
    echo "  vscode: settings.json not found in source — skipping"
fi

cat > "$CODE_DIR/keybindings.json" << KEYBINDINGS_EOF
// Place your key bindings in this file to override the defaults
[
    {
        "key": "ctrl+i",
        "command": "composerMode.agent"
    },
    {
        "key": "ctrl+alt+s",
        "command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
        "when": "cursor.agentIdeUnification.enabled == true && !isAuxiliaryWindowFocusedContext"
    },
    {
        "key": "ctrl+o ctrl+m",
        "command": "workbench.action.files.openFolder",
        "args": { "defaultUri": "$WORKSPACE_PATH" }
    }
]
KEYBINDINGS_EOF
echo "  vscode: keybindings.json deployed"

SNIPPETS_SRC="${CHEZMOI_SOURCE}/cursor/snippets"
if [[ -d "$SNIPPETS_SRC" ]] && ls "$SNIPPETS_SRC"/*.code-snippets &>/dev/null; then
    mkdir -p "$CODE_DIR/snippets"
    cp "$SNIPPETS_SRC"/*.code-snippets "$CODE_DIR/snippets/"
    echo "  vscode: snippets deployed"
fi

# Extensions: use ./scripts/vscode-sync-extensions.sh when needed (not on every apply)
else
    echo "  vscode: settings directory not found — skipping ($CODE_DIR)"
fi
