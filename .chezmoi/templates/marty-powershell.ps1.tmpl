{{- /* chezmoi: managed PowerShell profile body (Windows) */ -}}
{{- $starship := false -}}
{{- $prediction := "none" -}}
{{- $predview := "inline" -}}
{{- with .ps -}}
{{- $starship = .starship | default false -}}
{{- $prediction = .prediction | default "none" -}}
{{- $predview = .predictionview | default "inline" -}}
{{- end -}}
# ══════════════════════════════════════════════════════════════════════════════
#  PowerShell profile — Marty's dotfiles (chezmoi)
#
#  Do not edit this file directly. Source: chezmoi edit $PROFILE
#  Pull updates: dotup   ·  Push local IDE + source changes: dotupload   ·  Preferences: dotps wizard   ·  Disable extras: undotps
# ══════════════════════════════════════════════════════════════════════════════

$__martyLocalBin = Join-Path $env:USERPROFILE '.local\bin'
if (Test-Path -LiteralPath $__martyLocalBin) {
    $env:Path = $__martyLocalBin + [IO.Path]::PathSeparator + $env:Path
}

# Startup log level: unset / minimal = one line + errors; warn = + compact detail; debug = full dump.
# Env: MARTY_DOTFILES_LOG = warn | debug  (also 1|2, verbose, all). MARTY_DOTFILES_DIAG_QUIET=1 -> minimal.
# On demand:  Show-MartyDotfilesDiag warn  |  Show-MartyDotfilesDiag debug  (positional or -Tier). No args -> warn tier.
function Get-MartyDotfilesLogLevel {
    if ($env:MARTY_DOTFILES_DIAG_QUIET) { return 0 }
    $t = ([string]$env:MARTY_DOTFILES_LOG).Trim().ToLowerInvariant()
    switch ($t) {
        { $_ -in @('warn', 'warning', '1') } { return 1 }
        { $_ -in @('debug', 'verbose', '2', 'all', 'true', 'yes') } { return 2 }
        default { return 0 }
    }
}
$MartyDotfilesLogLevel = Get-MartyDotfilesLogLevel

function Marty-WriteDotfilesDiagOneCmd {
    param([string]$Name)
    $c = Get-Command $Name -ErrorAction SilentlyContinue
    if ($c) {
        Write-Host ("  [ok] $Name -> " + $c.Source) -ForegroundColor Green
        try {
            switch ($Name) {
                'chezmoi' {
                    & chezmoi --version 2>&1 | Select-Object -First 4 | ForEach-Object { Write-Host ('        | ' + $_) -ForegroundColor DarkGray }
                    $spRaw = & chezmoi source-path 2>$null
                    $sp = if ($null -ne $spRaw) { [string](@($spRaw)[0]).Trim() } else { '' }
                    if ($sp) {
                        $sd = Join-Path $sp 'scripts'
                        Write-Host ('        | source-path=' + $sp + '  scripts=' + (Test-Path -LiteralPath $sd)) -ForegroundColor DarkGray
                    } else {
                        Write-Host '        | source-path failed' -ForegroundColor Yellow
                    }
                }
                'git' { Write-Host ('        | ' + (& git --version 2>&1)) -ForegroundColor DarkGray }
                'starship' {
                    & starship --version 2>&1 | Select-Object -First 3 | ForEach-Object { Write-Host ('        | ' + $_) -ForegroundColor DarkGray }
                    Write-Host ('        | STARSHIP_CONFIG=' + [string]$env:STARSHIP_CONFIG) -ForegroundColor DarkGray
                }
            }
        } catch {
            Write-Host ("        | (version check failed: $($_.Exception.Message))") -ForegroundColor Yellow
        }
    } else {
        Write-Host "  [warn] $Name not on PATH" -ForegroundColor Yellow
    }
}

function Marty-WriteDotfilesDiagWarn {
    Write-Host ''
    Write-Host '  --- dotfiles | warn (MARTY_DOTFILES_LOG=warn or Show-MartyDotfilesDiag warn) ---' -ForegroundColor DarkCyan
    Write-Host ('  utc=' + (Get-Date).ToUniversalTime().ToString('yyyy-MM-ddTHH:mm:ssZ') +
        '  PS=' + $PSVersionTable.PSVersion + '  PSEdition=' + $PSVersionTable.PSEdition)
    Write-Host ('  PWD=' + (Get-Location).Path)
    Write-Host ('  PROFILE=' + $PROFILE)
    Marty-WriteDotfilesDiagOneCmd chezmoi
    Marty-WriteDotfilesDiagOneCmd git
    Marty-WriteDotfilesDiagOneCmd starship
    Write-Host ('  tmpl: starship={{ $starship }}  prediction={{ $prediction }}  view={{ $predview }}') -ForegroundColor DarkGray
    try {
        $raw = chezmoi data --format json 2>$null
        if ($raw) {
            $dj = $raw | ConvertFrom-Json
            if ($dj.ps) {
                Write-Host ('  chezmoi_data.ps=' + ($dj.ps | ConvertTo-Json -Compress -Depth 4 -ErrorAction SilentlyContinue)) -ForegroundColor DarkGray
            }
        } else {
            Write-Host '  chezmoi_data=(empty or failed)' -ForegroundColor Yellow
        }
    } catch {
        Write-Host ("  chezmoi_data=(exception: $($_.Exception.Message))") -ForegroundColor Yellow
    }
    Write-Host '  full dump: MARTY_DOTFILES_LOG=debug  or  Show-MartyDotfilesDiag debug' -ForegroundColor DarkGray
    Write-Host ''
}

function Marty-WriteDotfilesDiagDebug {
    $__mBar = '=============================================================='
    Write-Host ''
    Write-Host $__mBar -ForegroundColor DarkCyan
    Write-Host '  [marty-dotfiles | PowerShell | DEBUG | paste to support]' -ForegroundColor Cyan
    Write-Host $__mBar -ForegroundColor DarkCyan
    Write-Host ('  utc_now=' + (Get-Date).ToUniversalTime().ToString('yyyy-MM-ddTHH:mm:ssZ'))
    Write-Host ('  PSVersion=' + $PSVersionTable.PSVersion + ' PSEdition=' + $PSVersionTable.PSEdition)
    try {
        Write-Host ('  CLR=' + [System.Runtime.InteropServices.RuntimeInformation]::FrameworkDescription)
    } catch {
        Write-Host '  CLR=(unavailable)' -ForegroundColor Yellow
    }
    Write-Host ('  OS=' + [System.Environment]::OSVersion.VersionString)
    Write-Host ('  Machine=' + [System.Environment]::MachineName + ' User=' + [System.Environment]::UserName + ' Interactive=' + [System.Environment]::UserInteractive)
    try {
        Write-Host ('  Host=' + $Host.Name + ' UI=' + $Host.UI.RawUI.WindowSize.Width + 'x' + $Host.UI.RawUI.WindowSize.Height)
    } catch {
        Write-Host ('  Host=' + $Host.Name + ' UI=(non-console)') -ForegroundColor DarkGray
    }
    Write-Host ('  PWD=' + (Get-Location).Path)
    Write-Host ('  PROFILE=' + $PROFILE)
    Write-Host ('  PSCommandPath=' + [string]$PSCommandPath)
    Write-Host ('  USERPROFILE=' + $env:USERPROFILE)
    Write-Host ('  TERM=' + [string]$env:TERM + ' NO_COLOR=' + [string]$env:NO_COLOR)
    Write-Host ('  PathLen=' + $env:Path.Length)
    Write-Host ('  Path=' + $env:Path)
    Write-Host ('  tmpl_starship_block_enabled={{ $starship }}  tmpl_prediction={{ $prediction }}  tmpl_predictionview={{ $predview }}')
    Marty-WriteDotfilesDiagOneCmd chezmoi
    Marty-WriteDotfilesDiagOneCmd git
    Marty-WriteDotfilesDiagOneCmd starship
    try {
        $raw = chezmoi data --format json 2>$null
        if ($raw) {
            $dj = $raw | ConvertFrom-Json
            $psJson = '{}'
            if ($dj.ps) { $psJson = ($dj.ps | ConvertTo-Json -Compress -Depth 4 -ErrorAction SilentlyContinue) }
            Write-Host ('  chezmoi_data.ps=' + $psJson) -ForegroundColor DarkGray
        } else {
            Write-Host '  chezmoi_data=(empty or chezmoi data failed)' -ForegroundColor Yellow
        }
    } catch {
        Write-Host ("  chezmoi_data=(exception: $($_.Exception.Message))") -ForegroundColor Yellow
    }
    Write-Host $__mBar -ForegroundColor DarkCyan
    Write-Host '  hint: $env:MARTY_DOTFILES_LOG unset=minimal | warn | debug' -ForegroundColor DarkGray
    Write-Host ''
}

function Show-MartyDotfilesDiag {
    param(
        [Parameter(Position = 0)]
        [string] $Tier = 'warn'
    )
    $n = $Tier.Trim().ToLowerInvariant()
    if ($n -in @('warn', 'warning', '1')) {
        Marty-WriteDotfilesDiagWarn
    } elseif ($n -in @('debug', 'verbose', '2', 'all', 'true', 'yes')) {
        Marty-WriteDotfilesDiagDebug
    } else {
        Write-Error "Show-MartyDotfilesDiag: unknown tier '$Tier' (use warn or debug)."
    }
}

# After `cd`: subfolders only, names in horizontal columns (Format-Wide).
function Show-MartySubfoldersWide {
    $dirs = @(
        Microsoft.PowerShell.Management\Get-ChildItem -Directory -ErrorAction SilentlyContinue |
            Sort-Object { $_.Name.ToLowerInvariant() }
    )
    if ($dirs.Count -eq 0) {
        Write-Host '  (no subfolders)' -ForegroundColor DarkGray
        return
    }
    Write-Host ''
    $dirs | Format-Wide -Property Name -AutoSize
}

# ls/dir: one listing sorted by name (case-insensitive); folder names Cyan, file names Gray; metadata DarkGray.
# For dirs-first instead, sort with: Sort-Object @{E={-not $_.PSIsContainer}}, @{E={$_.Name.ToLowerInvariant()}}
function Show-MartyColoredChildListing {
    [CmdletBinding()]
    param([Parameter(ValueFromPipeline = $true)] $InputObject)
    begin { $items = [System.Collections.Generic.List[object]]::new() }
    process {
        if ($null -ne $InputObject) { [void]$items.Add($InputObject) }
    }
    end {
        if ($items.Count -eq 0) {
            Write-Host '  (empty)' -ForegroundColor DarkGray
            return
        }
        $sorted = $items | Sort-Object { $_.Name.ToLowerInvariant() }
        foreach ($it in $sorted) {
            $mode = [string]$it.Mode
            $time = if ($null -ne $it.LastWriteTime) {
                $it.LastWriteTime.ToString('MM/dd/yyyy  hh:mm tt')
            } else { '' }
            $lenStr = if ($it.PSIsContainer) { '' } else { [string]$it.Length }
            $meta = ('{0,-10} {1,-22} {2,14}   ' -f $mode, $time, $lenStr)
            Write-Host $meta -NoNewline -ForegroundColor DarkGray
            $nameColor = if ($it.PSIsContainer) { 'Cyan' } else { 'Gray' }
            Write-Host $it.Name -ForegroundColor $nameColor
        }
    }
}

Remove-Item -Path alias:ls, alias:dir -Force -ErrorAction SilentlyContinue
function ls {
    [CmdletBinding(DefaultParameterSetName = 'Items')]
    param(
        [Parameter(ParameterSetName = 'Items', Position = 0)]
        [string[]] $Path,
        [Parameter(ParameterSetName = 'LiteralItems', Mandatory = $true)]
        [string[]] $LiteralPath,
        [string] $Filter,
        [switch] $Force,
        # -h / -Hidden: show hidden items (maps to Get-ChildItem -Force on Windows PowerShell)
        [Alias('h')]
        [switch] $Hidden,
        [switch] $Recurse,
        [switch] $File,
        [switch] $Directory,
        [switch] $Name,
        [string[]] $Include,
        [string[]] $Exclude
    )
    $splat = @{}
    foreach ($key in $PSBoundParameters.Keys) {
        if ($key -in @('Name', 'Hidden')) { continue }
        $splat[$key] = $PSBoundParameters[$key]
    }
    if ($Hidden) { $splat['Force'] = $true }
    if ($PSCmdlet.ParameterSetName -eq 'Items' -and -not $splat.ContainsKey('Path')) {
        $splat['Path'] = @('.')
    }
    $cmd = Get-Command Get-ChildItem -CommandType Cmdlet
    if ($Name) {
        & $cmd @splat -Name
    } else {
        & $cmd @splat | Show-MartyColoredChildListing
    }
}
# Built-in `dir` is AllScope; replacing it with Set-Alias without -Option AllScope throws
# "The AllScope option cannot be removed from the alias 'dir'." Use AllScope here too.
Set-Alias -Name dir -Value ls -Scope Global -Option AllScope -Force

# ZSH-style: cd then list (matches dot_zshrc.tmpl). Skip extra listing when -PassThru (pipeline contract).
function cd {
    [CmdletBinding(DefaultParameterSetName = 'Path')]
    param(
        [Parameter(ParameterSetName = 'Path', Position = 0, ValueFromPipeline = $true, ValueFromPipelineByPropertyName = $true)]
        [string] $Path,
        [Parameter(ParameterSetName = 'LiteralPath', Mandatory = $true, ValueFromPipelineByPropertyName = $true)]
        [string] $LiteralPath,
        [switch] $PassThru,
        [Parameter(ParameterSetName = 'Path')]
        [Parameter(ParameterSetName = 'LiteralPath')]
        [string] $StackName
    )
    process {
        $splat = @{}
        foreach ($k in $PSBoundParameters.Keys) {
            $splat[$k] = $PSBoundParameters[$k]
        }
        if ($PSCmdlet.ParameterSetName -eq 'Path' -and -not $splat.ContainsKey('Path') -and -not $splat.ContainsKey('StackName')) {
            $splat['Path'] = $HOME
        }
        $pi = Microsoft.PowerShell.Management\Set-Location @splat
        if (-not $?) { return }
        if (-not $PassThru) {
            Show-MartySubfoldersWide
        }
        if ($PassThru) {
            Write-Output -InputObject $pi
        }
    }
}

function Get-MartyChezmoiSource {
    try {
        $out = & chezmoi source-path 2>$null
        if ($out) { return $out.Trim() }
    } catch {}
    return $null
}

# Resolves .../scripts even if chezmoi source-path fails (e.g. PATH not refreshed yet).
function Get-MartyDotfilesScriptsDir {
    $candidates = [System.Collections.Generic.List[string]]::new()
    $src = Get-MartyChezmoiSource
    if ($src) { [void]$candidates.Add((Join-Path $src 'scripts')) }
    [void]$candidates.Add((Join-Path $env:USERPROFILE '.local\share\chezmoi\scripts'))
    foreach ($d in $candidates) {
        if (Test-Path -LiteralPath (Join-Path $d 'dotps.ps1')) { return $d }
    }
    return $null
}

function dotup { chezmoi update @args }
function dotapply { chezmoi apply -v @args }
function dotdiff { chezmoi diff @args }
function dotedit { chezmoi edit @args }
function dots {
    $src = Get-MartyChezmoiSource
    if ($src) { cd -LiteralPath $src }
    else { Write-Error 'chezmoi source-path failed — is chezmoi installed?' }
}
function dottools {
    $dir = Get-MartyDotfilesScriptsDir
    if (-not $dir) { Write-Error 'chezmoi scripts not found — install dotfiles or ensure ~/.local/share/chezmoi/scripts exists'; return }
    $p = Join-Path $dir 'dottools.ps1'
    if (-not (Test-Path -LiteralPath $p)) { Write-Error "dottools: not found: $p"; return }
    & $p @args
}
function dotupload {
    $dir = Get-MartyDotfilesScriptsDir
    if (-not $dir) { Write-Error 'chezmoi scripts not found — install dotfiles or ensure ~/.local/share/chezmoi/scripts exists'; return }
    $p = Join-Path $dir 'dotupload.ps1'
    if (-not (Test-Path -LiteralPath $p)) { Write-Error "dotupload: not found: $p"; return }
    & $p @args
}
# Pass a single subcommand string — do not splat @args into dotps.ps1 (PS 5.1 treats starship-off as a switch name).
function dotps {
    param(
        [Parameter(Position = 0)]
        [string] $Cmd = 'show'
    )
    if ($Cmd -in @('starshipon', 'starshipoff', 'starship-on', 'starship-off', 'starshipupdate')) {
        Write-Warning 'Starship sync toggles are disabled for PowerShell in this setup.'
        return
    }
    $dir = Get-MartyDotfilesScriptsDir
    if (-not $dir) { Write-Error 'chezmoi scripts not found — install dotfiles or ensure ~/.local/share/chezmoi/scripts exists'; return }
    & (Join-Path $dir 'dotps.ps1') $Cmd
}
function undotps { dotps off }

function starshipon {
    Write-Warning 'starshipon is disabled in PowerShell (sync path disabled).'
}
function starshipoff {
    Write-Warning 'starshipoff is disabled in PowerShell (sync path disabled).'
}
function Invoke-MartyStarshipUpdateInstall {
    Write-Host ''
    Write-Host '  starshipupdate' -ForegroundColor Cyan
    Write-Host ''
    if (Get-Command winget -ErrorAction SilentlyContinue) {
        Write-Host '  winget upgrade Starship.Starship...' -ForegroundColor DarkGray
        winget upgrade --id Starship.Starship -e --accept-package-agreements --accept-source-agreements 2>&1 | Out-Null
    }
    $env:Path = [System.Environment]::GetEnvironmentVariable('Path', 'Machine') + ';' + [System.Environment]::GetEnvironmentVariable('Path', 'User')
    Write-Host '  https://starship.rs/install.ps1 ...' -ForegroundColor DarkGray
    try {
        [Net.ServicePointManager]::SecurityProtocol = [Net.ServicePointManager]::SecurityProtocol -bor [Net.SecurityProtocolType]::Tls12
    } catch {}
    Invoke-Expression (Invoke-RestMethod -Uri 'https://starship.rs/install.ps1' -UseBasicParsing)
    $env:Path = [System.Environment]::GetEnvironmentVariable('Path', 'Machine') + ';' + [System.Environment]::GetEnvironmentVariable('Path', 'User')
    if (Get-Command starship -ErrorAction SilentlyContinue) {
        Write-Host ('  OK: ' + (& starship --version 2>$null)) -ForegroundColor Green
    } else {
        Write-Warning '  starship not on PATH — open a new terminal.'
    }
}
function starshipupdate {
    Write-Warning 'starshipupdate is disabled in PowerShell (sync path disabled).'
}

# ── PSReadLine prediction (pwsh 7.2+ / PSReadLine 2.2+) ─────────────────────
if (Get-Module -ListAvailable -Name PSReadLine) {
    Import-Module PSReadLine -ErrorAction SilentlyContinue
    $MartyPred = '{{ $prediction }}'
    $MartyPredView = '{{ $predview }}'
    try {
        switch ($MartyPred) {
            'none' {
                Set-PSReadLineOption -PredictionSource None -ErrorAction Stop
            }
            'history' {
                Set-PSReadLineOption -PredictionSource History -ErrorAction Stop
                if ($MartyPredView -eq 'list') {
                    Set-PSReadLineOption -PredictionViewStyle ListView -ErrorAction Stop
                } else {
                    Set-PSReadLineOption -PredictionViewStyle InlineView -ErrorAction Stop
                }
            }
            'historyandplugin' {
                Set-PSReadLineOption -PredictionSource HistoryAndPlugin -ErrorAction Stop
                if ($MartyPredView -eq 'list') {
                    Set-PSReadLineOption -PredictionViewStyle ListView -ErrorAction Stop
                } else {
                    Set-PSReadLineOption -PredictionViewStyle InlineView -ErrorAction Stop
                }
            }
        }
    } catch {
        # PS 5.1 or older PSReadLine without prediction APIs — ignore
    }
    try {
        Set-PSReadLineKeyHandler -Key Tab -Function MenuComplete -ErrorAction Stop
    } catch {
        # Older PSReadLine without MenuComplete — keep default Tab behavior
    }
    try {
        Set-PSReadLineOption -ShowToolTips -ErrorAction Stop
    } catch {
        # Not available on all PSReadLine versions
    }
    try {
        Set-PSReadLineOption -Colors @{
            Command            = "`e[93m"
            Parameter          = "`e[96m"
            Operator           = "`e[35m"
            Variable           = "`e[92m"
            String             = "`e[33m"
            Number             = "`e[35m"
            Member             = "`e[97m"
            Type               = "`e[95m"
            Comment            = "`e[32m"
            InlinePrediction   = "`e[38;5;102m"
            Selection          = "`e[7m"
        } -ErrorAction Stop
    } catch {
        # Older PSReadLine / strict hosts
    }
}

{{- if $starship }}

# ── Starship prompt ─────────────────────────────────────────────────────────
# Transient prompt: full line for the active prompt, compact `character` for history (see https://starship.rs/advanced-config/ ).
if (Get-Command starship -ErrorAction SilentlyContinue) {
    function Invoke-Starship-TransientFunction {
        & starship module character
    }
    Invoke-Expression (& starship init powershell)
    try {
        Enable-TransientPrompt
    } catch {
        # Starship build without transient API — keep normal prompt
    }
} else {
    if ($MartyDotfilesLogLevel -ge 1) {
        Write-Warning 'Starship is enabled in dotps settings but not on PATH. Install: winget install Starship.Starship, then dotapply'
    }
}
{{- end }}

# ── Startup summary (after profile body; respects MARTY_DOTFILES_LOG) ────────
$__mProfileErrs = [System.Collections.Generic.List[string]]::new()
if (-not (Get-Command chezmoi -ErrorAction SilentlyContinue)) {
    [void]$__mProfileErrs.Add('chezmoi not on PATH')
}
foreach ($__m in $__mProfileErrs) {
    Write-Host ('  dotfiles: error - ' + $__m) -ForegroundColor Red
}
if ([Environment]::UserInteractive) {
    switch ($MartyDotfilesLogLevel) {
        0 {
            if ($__mProfileErrs.Count -gt 0) {
                Write-Host '  dotfiles: started with errors (Show-MartyDotfilesDiag warn for detail)' -ForegroundColor Yellow
            } else {
                Write-Host ('  dotfiles: ok | PS ' + $PSVersionTable.PSVersion + ' | ' + [IO.Path]::GetFileName($PROFILE)) -ForegroundColor DarkGreen
            }
        }
        1 {
            if ($__mProfileErrs.Count -gt 0) {
                Write-Host ('  dotfiles: problems above | PS ' + $PSVersionTable.PSVersion) -ForegroundColor Yellow
            } else {
                Write-Host ('  dotfiles: ok | PS ' + $PSVersionTable.PSVersion) -ForegroundColor DarkGreen
            }
            Marty-WriteDotfilesDiagWarn
        }
        2 {
            Marty-WriteDotfilesDiagDebug
        }
    }
}
Remove-Variable -Name __mProfileErrs -ErrorAction SilentlyContinue
